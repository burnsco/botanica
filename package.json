{
  "name": "botanica",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "bun run build && wrangler dev --config dist/server/wrangler.json",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.2.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "6.1.10",
    "wrangler": "4.86.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "tailwindcss": "^4.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.3.11"
}
